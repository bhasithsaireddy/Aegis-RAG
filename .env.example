# Noir Atlas — Environment Variables Example
# Copy this to .env and customize as needed

# --- Python Backend ---
# Override the Python executable used to start the backend
# Useful if you have multiple Python versions
# AEGIS_RAG_PYTHON=/path/to/your/python

# --- Ollama Configuration ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=mistral:7b
VISION_MODEL=llava
EMBEDDING_MODEL=nomic-embed-text

# --- Voice / Whisper ---
# Options: tiny, base, small, medium, large-v2
WHISPER_MODEL=base

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K_RESULTS=5
USE_RERANKER=true
# Enable experimental hybrid (BM25 + dense) search
USE_HYBRID_SEARCH=false

# --- API Server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Paths (optional overrides) ---
# CHROMA_DIR=data/chroma_db
# UPLOADS_DIR=data/uploads
# MODELS_DIR=models
